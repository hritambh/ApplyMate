# Server
PORT=4000
# LOG_LEVEL=debug
CLIENT_URL=http://localhost:5173

# Encrypt per-user SMTP passwords at rest (required for profiles)
# Generate: openssl rand -hex 32
PROFILE_ENCRYPTION_KEY=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI must be the SERVER callback, e.g.:
#   http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
JWT_SECRET=change-me-in-production

# OpenAI (server-wide — used to generate cover letters for all users)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Set to 'true' to let EVERY user generate with the shared OPENAI_API_KEY above,
# bypassing the per-user credit system entirely (no credits consumed).
# OPENAI_SHARED_KEY_FOR_ALL=true

# Per-user applicant + SMTP settings are configured in the app after login
# (Profile setup screen). Previously these lived in .env:
# APPLICANT_NAME, APPLICANT_HEADLINE, APPLICANT_SKILLS, APPLICANT_PHONE
# SMTP_HOST, SMTP_PORT, SMTP_SECURE, SMTP_USER, SMTP_PASS
# MAIL_FROM_NAME, MAIL_FROM_ADDRESS

# Email existence check (SMTP/MX probe — port 25 must be reachable)
# SKIP_EMAIL_VALIDATION=true
# EMAIL_CHECK_TIMEOUT_MS=15000
