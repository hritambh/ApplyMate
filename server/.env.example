# Server
PORT=4000
# LOG_LEVEL=debug

# OpenAI (used to generate cover letters)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Personal info injected into the cover letter prompt (optional but recommended)
APPLICANT_NAME=Your Name
APPLICANT_HEADLINE=Software Engineer with 3 years of experience in Node.js and React
APPLICANT_SKILLS=Node.js, React, TypeScript, AWS, PostgreSQL

# SMTP — Gmail example. For Gmail, create an App Password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# "From" header on outgoing mails (defaults to SMTP_USER if omitted)
MAIL_FROM_NAME=Your Name
MAIL_FROM_ADDRESS=you@gmail.com

# Email existence check (SMTP/MX probe — port 25 must be reachable)
# SKIP_EMAIL_VALIDATION=true
# EMAIL_CHECK_TIMEOUT_MS=15000
