{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Backend (port 9235)",
      "port": 9235,
      "address": "127.0.0.1",
      "restart": true,
      "cwd": "${workspaceFolder}/server",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run Backend",
      "cwd": "${workspaceFolder}/server",
      "program": "${workspaceFolder}/server/src/index.js",
      "runtimeArgs": ["--watch"],
      "envFile": "${workspaceFolder}/server/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
